    "dimension": 68,
    "n_heads": 10,
    "n_layers": 3
  },
  "embedding_size": 512,
  "save_model": false,
  "tensorboard": {
    "training": true,
    "embedding": true,
    "comment": "tensorboard_example"
  }
}
**Key insights:**
- These are **experiment configuration files** for training the BIONIC neural network model
- Each config specifies training hyperparameters, network architecture (GAT), input/output paths, and model settings
