    "dimension": 68,
    "n_heads": 10,
    "n_layers": 3
  },
  "embedding_size": 512,
  "save_model": false,
  "model_parallel": true
}
3. **yeast_gi_coex_ppi_semisupervised.json** - Semi-supervised variant of the yeast configuration (larger file size suggests additional semi-supervised parameters)
{
  "net_names": [
